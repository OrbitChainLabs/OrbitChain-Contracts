# Dependencies
/target
# Cargo.lock is committed: this workspace ships deployable contracts and
# verifies WASM hashes, both of which require a reproducible dependency graph.
# It also stops an unbounded upstream range (e.g. soroban-env-host's
# `ed25519-dalek = ">=2.0.0"`) from silently resolving to a breaking major.

# Environment
.env
.env.local
.env.testnet
.env.mainnet

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Build artifacts
*.wasm
*.d

# Soroban
.stellar/
soroban.toml

# Deployment records (contain network-specific contract IDs; committed per-env as needed)
deployments/*.json
.orbitchain_contract_id

